{
  "manifest_version": 3,
  "name": "蝦皮同店購物助手 Shopee Same-Store Finder",
  "version": "0.1.0",
  "description": "一次輸入多個商品，找出同時販售這些商品的蝦皮賣場，在同一家店湊免運。",
  "action": {
    "default_title": "Seller Intersection",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["*://*.shopee.tw/*", "*://*.shopee.sg/*", "*://*.shopee.co.th/*", "*://*.shopee.com.my/*", "*://*.shopee.ph/*", "*://*.shopee.vn/*", "*://*.shopee.co.id/*", "*://*.shopee.com.br/*"],
  "content_scripts": [
    {
      "matches": ["*://*.shopee.tw/*", "*://*.shopee.sg/*", "*://*.shopee.co.th/*", "*://*.shopee.com.my/*", "*://*.shopee.ph/*", "*://*.shopee.vn/*", "*://*.shopee.co.id/*", "*://*.shopee.com.br/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_appName__",
  "version": "0.1.2",
  "description": "__MSG_appDesc__",
  "action": {
    "default_title": "__MSG_appName__",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*",
    "*://*.shopee.tw/*",
    "*://*.shopee.sg/*",
    "*://*.shopee.co.th/*",
    "*://*.shopee.com.my/*",
    "*://*.shopee.ph/*",
    "*://*.shopee.vn/*",
    "*://*.shopee.co.id/*",
    "*://*.shopee.com.br/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.shopee.tw/search*",
        "*://*.shopee.sg/search*",
        "*://*.shopee.co.th/search*",
        "*://*.shopee.com.my/search*",
        "*://*.shopee.ph/search*",
        "*://*.shopee.vn/search*",
        "*://*.shopee.co.id/search*",
        "*://*.shopee.com.br/search*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
